# llm-router — copy to .env and fill in. NEVER commit your real .env.

# Provider: "openai" (any OpenAI-compatible endpoint) or "yandex"
LLM_PROVIDER=openai

# --- OpenAI-compatible (OpenAI / Alibaba Qwen / OpenRouter / Together / Ollama) ---
OPENAI_API_KEY=
# Point at a different provider by changing the base URL (no /chat/completions):
#   OpenAI:     https://api.openai.com/v1            (default)
#   Alibaba:    https://<your-endpoint>/compatible-mode/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:     http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# role -> model
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_MID_MODEL=gpt-4o-mini
LLM_CHIEF_MODEL=gpt-4o
LLM_AUDIT_MODEL=gpt-4o

# --- Yandex AI Studio (only if LLM_PROVIDER=yandex) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Optional explicit URIs (otherwise built as gpt://<folder>/<name>/latest):
# YANDEX_CHEAP_MODEL=gpt://<folder>/yandexgpt-lite/latest
# YANDEX_CHIEF_MODEL=gpt://<folder>/yandexgpt/latest

# --- cost logging ---
LLM_FX=1.0          # USD -> local currency multiplier (e.g. 90 for RUB)
LLM_CCY=USD         # local currency label
# Override prices per model (USD per 1M tokens):
# LLM_PRICE_GPT_4O_MINI_IN_USD_PER_1M=0.15
# LLM_PRICE_GPT_4O_MINI_OUT_USD_PER_1M=0.60
# Optional cap used by budget helpers (your app still owns the usage log):
# LLM_BUDGET_USD_DAY=1.00

# --- behavior ---
LLM_DEFAULT_TIMEOUT=60
LLM_MAX_RETRIES=2
